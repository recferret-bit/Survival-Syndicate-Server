datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../../prisma/matchmaking-service/generated"
}

model MatchmakingLobby {
  id        String   @id @default(uuid())
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("matchmaking_lobby")
}
