{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "monorepo": true,
  "root": "apps",
  "projects": {
    "gameplay-service": {
      "type": "application",
      "root": "apps/gameplay-service",
      "entryFile": "main",
      "sourceRoot": "apps/gameplay-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/gameplay-service/tsconfig.app.json"
      }
    },
    "local-orchestrator": {
      "type": "application",
      "root": "apps/local-orchestrator",
      "entryFile": "main",
      "sourceRoot": "apps/local-orchestrator/src",
      "compilerOptions": {
        "tsConfigPath": "apps/local-orchestrator/tsconfig.app.json"
      }
    },
    "matchmaking-service": {
      "type": "application",
      "root": "apps/matchmaking-service",
      "entryFile": "main",
      "sourceRoot": "apps/matchmaking-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/matchmaking-service/tsconfig.app.json"
      }
    },
    "player-service": {
      "type": "application",
      "root": "apps/player-service",
      "entryFile": "main",
      "sourceRoot": "apps/player-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/player-service/tsconfig.app.json"
      }
    },
    "users-service": {
      "type": "application",
      "root": "apps/users-service",
      "entryFile": "main",
      "sourceRoot": "apps/users-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/users-service/tsconfig.app.json"
      }
    },
    "websocket-service": {
      "type": "application",
      "root": "apps/websocket-service",
      "entryFile": "main",
      "sourceRoot": "apps/websocket-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/websocket-service/tsconfig.app.json"
      }
    },
    "shared": {
      "type": "library",
      "root": "libs/shared",
      "entryFile": "index",
      "sourceRoot": "libs/shared/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/tsconfig.lib.json"
      }
    },
    "lib-gameplay": {
      "type": "library",
      "root": "libs/lib-gameplay",
      "entryFile": "index",
      "sourceRoot": "libs/lib-gameplay/src",
      "compilerOptions": {
        "tsConfigPath": "libs/lib-gameplay/tsconfig.lib.json"
      }
    },
    "lib-local-orchestrator": {
      "type": "library",
      "root": "libs/lib-local-orchestrator",
      "entryFile": "index",
      "sourceRoot": "libs/lib-local-orchestrator/src",
      "compilerOptions": {
        "tsConfigPath": "libs/lib-local-orchestrator/tsconfig.lib.json"
      }
    },
    "lib-matchmaking": {
      "type": "library",
      "root": "libs/lib-matchmaking",
      "entryFile": "index",
      "sourceRoot": "libs/lib-matchmaking/src",
      "compilerOptions": {
        "tsConfigPath": "libs/lib-matchmaking/tsconfig.lib.json"
      }
    },
    "lib-player": {
      "type": "library",
      "root": "libs/lib-player",
      "entryFile": "index",
      "sourceRoot": "libs/lib-player/src",
      "compilerOptions": {
        "tsConfigPath": "libs/lib-player/tsconfig.lib.json"
      }
    },
    "lib-users": {
      "type": "library",
      "root": "libs/lib-users",
      "entryFile": "index",
      "sourceRoot": "libs/lib-users/src",
      "compilerOptions": {
        "tsConfigPath": "libs/lib-users/tsconfig.lib.json"
      }
    },
    "lib-websocket": {
      "type": "library",
      "root": "libs/lib-websocket",
      "entryFile": "index",
      "sourceRoot": "libs/lib-websocket/src",
      "compilerOptions": {
        "tsConfigPath": "libs/lib-websocket/tsconfig.lib.json"
      }
    }
  }
}
