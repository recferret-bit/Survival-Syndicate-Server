# Copy to .env and adjust. Required for `npm run start:local` so each service has a unique port.

# Infrastructure (e.g. npm run docker:infra)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_META_DB=survival_meta
POSTGRES_CATALOG_DB=survival_catalog
NATS_PORT=4222
REDIS_PORT=6379

# For prisma:migrate:dev — direct Postgres (to create DBs and shadow). With docker:infra: postgres on 5432.
# POSTGRES_BASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
# If unset, derived from TEST_DIRECT_USERS_DATABASE_URL or PGBOUNCER_USERS_DATABASE_URL.
# PRISMA_USE_TEST_DATABASES=1 — use TEST_DIRECT_* URLs (users_test etc.) for migrate deploy; used by test:e2e:setup.

# Database URLs (when not using docker, point to your PostgreSQL)
# TEST_DIRECT_USERS_DATABASE_URL=postgresql://user:pass@localhost:5432/users_db
# PGBOUNCER_USERS_DATABASE_URL=postgresql://user:pass@localhost:5430/users_db?pgbouncer=true
# Same for PLAYER, MATCHMAKING, GAMEPLAY, LOCAL_ORCHESTRATOR, WEBSOCKET, BUILDING, etc.

NODE_ENV=development
JWT_SECRET=local-jwt-secret
PASSWORD_SECRET=local-password-secret

# App ports — must be unique when running all services (start:local)
SWAGGER_APP_PORT=3000
AUTH_APP_PORT=3001
PLAYER_APP_PORT=3002
MATCHMAKING_APP_PORT=3003
LOCAL_ORCHESTRATOR_APP_PORT=3004
GAMEPLAY_APP_PORT=3005
WEBSOCKET_APP_PORT=3006
BUILDING_APP_PORT=3007
COMBAT_PROGRESS_APP_PORT=3008
SCHEDULER_APP_PORT=3009
COLLECTOR_APP_PORT=3010
PAYMENT_APP_PORT=3011
HISTORY_APP_PORT=3012

# Database URLs for new services (prisma migrate, optional until service uses Prisma)
# PGBOUNCER_BUILDING_DATABASE_URL=postgresql://user:pass@localhost:5430/building_db?pgbouncer=true
# TEST_DIRECT_BUILDING_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/building_test
# Same for COMBAT_PROGRESS, SCHEDULER, COLLECTOR, PAYMENT, HISTORY.
