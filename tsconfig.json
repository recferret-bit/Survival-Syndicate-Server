{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@app/swagger-aggregator": ["apps/swagger-aggregator/src"],
      "@app/swagger-aggregator/*": ["apps/swagger-aggregator/src/*"],
      "@app/combat-progress-service": ["apps/combat-progress-service/src"],
      "@app/combat-progress-service/*": ["apps/combat-progress-service/src/*"],
      "@app/building-service": ["apps/building-service/src"],
      "@app/building-service/*": ["apps/building-service/src/*"],
      "@app/gameplay-service": ["apps/gameplay-service/src"],
      "@app/gameplay-service/*": ["apps/gameplay-service/src/*"],
      "@app/local-orchestrator": ["apps/local-orchestrator/src"],
      "@app/local-orchestrator/*": ["apps/local-orchestrator/src/*"],
      "@app/matchmaking-service": ["apps/matchmaking-service/src"],
      "@app/matchmaking-service/*": ["apps/matchmaking-service/src/*"],
      "@app/player-service": ["apps/player-service/src"],
      "@app/player-service/*": ["apps/player-service/src/*"],
      "@app/users-service": ["apps/users-service/src"],
      "@app/users-service/*": ["apps/users-service/src/*"],
      "@app/websocket-service": ["apps/websocket-service/src"],
      "@app/websocket-service/*": ["apps/websocket-service/src/*"],

      "@lib/lib-gameplay": ["libs/lib-gameplay/src"],
      "@lib/lib-gameplay/*": ["libs/lib-gameplay/src/*"],
      "@lib/lib-local-orchestrator": ["libs/lib-local-orchestrator/src"],
      "@lib/lib-local-orchestrator/*": ["libs/lib-local-orchestrator/src/*"],
      "@lib/lib-matchmaking": ["libs/lib-matchmaking/src"],
      "@lib/lib-matchmaking/*": ["libs/lib-matchmaking/src/*"],
      "@lib/lib-player": ["libs/lib-player/src"],
      "@lib/lib-player/*": ["libs/lib-player/src/*"],
      "@lib/lib-users": ["libs/lib-users/src"],
      "@lib/lib-users/*": ["libs/lib-users/src/*"],
      "@lib/lib-websocket": ["libs/lib-websocket/src"],
      "@lib/lib-websocket/*": ["libs/lib-websocket/src/*"],
      "@lib/lib-building": ["libs/lib-building/src"],
      "@lib/lib-building/*": ["libs/lib-building/src/*"],
      "@lib/lib-combat-progress": ["libs/lib-combat-progress/src"],
      "@lib/lib-combat-progress/*": ["libs/lib-combat-progress/src/*"],
      "@lib/lib-scheduler": ["libs/lib-scheduler/src"],
      "@lib/lib-scheduler/*": ["libs/lib-scheduler/src/*"],
      "@lib/lib-collector": ["libs/lib-collector/src"],
      "@lib/lib-collector/*": ["libs/lib-collector/src/*"],
      "@lib/lib-payment": ["libs/lib-payment/src"],
      "@lib/lib-payment/*": ["libs/lib-payment/src/*"],
      "@lib/lib-history": ["libs/lib-history/src"],
      "@lib/lib-history/*": ["libs/lib-history/src/*"],
      "@lib/shared": ["libs/shared/src"],
      "@lib/shared/*": ["libs/shared/src/*"],

      "@prisma/building": ["prisma/building/generated"],
      "@prisma/combat-progress": ["prisma/combat-progress/generated"],
      "@prisma/scheduler": ["prisma/scheduler/generated"],
      "@prisma/collector": ["prisma/collector/generated"],
      "@prisma/payment": ["prisma/payment/generated"],
      "@prisma/history": ["prisma/history/generated"],
      "@prisma/gameplay": ["prisma/gameplay/generated"],
      "@prisma/local-orchestrator": ["prisma/local-orchestrator/generated"],
      "@prisma/matchmaking": ["prisma/matchmaking/generated"],
      "@prisma/player": ["prisma/player/generated"],
      "@prisma/users": ["prisma/users/generated"],
      "@prisma/websocket": ["prisma/websocket/generated"]
    }
  }
}
