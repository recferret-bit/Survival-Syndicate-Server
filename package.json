{
  "name": "survival-syndicate-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rimraf dist",
    "build": "nest build --all",
    "build:all": "nest build --all",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint:fix": "eslint \"apps/**/*.ts\" \"libs/**/*.ts\" --fix",
    "prepare": "husky install",

    "start:gameplay-service": "nest start gameplay-service",
    "start:gameplay-service:dev": "nest start gameplay-service --watch",
    "start:gameplay-service:debug": "nest start gameplay-service --debug --watch",
    "start:local-orchestrator": "nest start local-orchestrator",
    "start:local-orchestrator:dev": "nest start local-orchestrator --watch",
    "start:local-orchestrator:debug": "nest start local-orchestrator --debug --watch",
    "start:matchmaking-service": "nest start matchmaking-service",
    "start:matchmaking-service:dev": "nest start matchmaking-service --watch",
    "start:matchmaking-service:debug": "nest start matchmaking-service --debug --watch",
    "start:player-service": "nest start player-service",
    "start:player-service:dev": "nest start player-service --watch",
    "start:player-service:debug": "nest start player-service --debug --watch",
    "start:users-service": "nest start users-service",
    "start:users-service:dev": "nest start users-service --watch",
    "start:users-service:debug": "nest start users-service --debug --watch",
    "start:websocket-service": "nest start websocket-service",
    "start:websocket-service:dev": "nest start websocket-service --watch",
    "start:websocket-service:debug": "nest start websocket-service --debug --watch",

    "start:local": "concurrently -n users,player,match,orch,gameplay,ws \"npx dotenv-cli -e .env -- nest start users-service\" \"npx dotenv-cli -e .env -- nest start player-service\" \"npx dotenv-cli -e .env -- nest start matchmaking-service\" \"npx dotenv-cli -e .env -- nest start local-orchestrator\" \"npx dotenv-cli -e .env -- nest start gameplay-service\" \"npx dotenv-cli -e .env -- nest start websocket-service\"",
    "start:prod": "node dist/apps/users-service/main",

    "prisma:generate": "npm run prisma:generate:users",
    "prisma:generate:users": "PRISMA_DB=users prisma generate --schema=prisma/users/schema.prisma",
    "prisma:generate:gameplay": "PRISMA_DB=gameplay prisma generate --schema=prisma/gameplay/schema.prisma",
    "prisma:generate:local-orchestrator": "PRISMA_DB=local-orchestrator prisma generate --schema=prisma/local-orchestrator/schema.prisma",
    "prisma:generate:matchmaking": "PRISMA_DB=matchmaking prisma generate --schema=prisma/matchmaking/schema.prisma",
    "prisma:generate:player": "PRISMA_DB=player prisma generate --schema=prisma/player/schema.prisma",
    "prisma:generate:websocket": "PRISMA_DB=websocket prisma generate --schema=prisma/websocket/schema.prisma",
    "prisma:migrate:dev": "npm run prisma:migrate:dev:users",
    "prisma:migrate:dev:users": "PRISMA_DB=users prisma migrate dev --schema=prisma/users/schema.prisma",
    "prisma:migrate:dev:gameplay": "PRISMA_DB=gameplay prisma migrate dev --schema=prisma/gameplay/schema.prisma",
    "prisma:migrate:dev:local-orchestrator": "PRISMA_DB=local-orchestrator prisma migrate dev --schema=prisma/local-orchestrator/schema.prisma",
    "prisma:migrate:dev:matchmaking": "PRISMA_DB=matchmaking prisma migrate dev --schema=prisma/matchmaking/schema.prisma",
    "prisma:migrate:dev:player": "PRISMA_DB=player prisma migrate dev --schema=prisma/player/schema.prisma",
    "prisma:migrate:dev:websocket": "PRISMA_DB=websocket prisma migrate dev --schema=prisma/websocket/schema.prisma",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy:users",
    "prisma:migrate:deploy:users": "PRISMA_DB=users prisma migrate deploy --schema=prisma/users/schema.prisma",
    "prisma:migrate:deploy:gameplay": "PRISMA_DB=gameplay prisma migrate deploy --schema=prisma/gameplay/schema.prisma",
    "prisma:migrate:deploy:local-orchestrator": "PRISMA_DB=local-orchestrator prisma migrate deploy --schema=prisma/local-orchestrator/schema.prisma",
    "prisma:migrate:deploy:matchmaking": "PRISMA_DB=matchmaking prisma migrate deploy --schema=prisma/matchmaking/schema.prisma",
    "prisma:migrate:deploy:player": "PRISMA_DB=player prisma migrate deploy --schema=prisma/player/schema.prisma",
    "prisma:migrate:deploy:websocket": "PRISMA_DB=websocket prisma migrate deploy --schema=prisma/websocket/schema.prisma",
    "prisma:studio:users": "PRISMA_DB=users prisma studio --schema=prisma/users/schema.prisma",
    "prisma:studio:gameplay": "PRISMA_DB=gameplay prisma studio --schema=prisma/gameplay/schema.prisma",
    "prisma:studio:local-orchestrator": "PRISMA_DB=local-orchestrator prisma studio --schema=prisma/local-orchestrator/schema.prisma",
    "prisma:studio:matchmaking": "PRISMA_DB=matchmaking prisma studio --schema=prisma/matchmaking/schema.prisma",
    "prisma:studio:player": "PRISMA_DB=player prisma studio --schema=prisma/player/schema.prisma",
    "prisma:studio:websocket": "PRISMA_DB=websocket prisma studio --schema=prisma/websocket/schema.prisma",
    "prisma:seed": "node prisma/users/seed.mjs",
    "prisma:reset": "npm run prisma:reset:users && npm run prisma:seed",
    "prisma:reset:users": "PRISMA_DB=users prisma migrate reset --schema=prisma/users/schema.prisma --force",

    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --testMatch='**/*.e2e-spec.ts' --runInBand",
    "test:integration": "jest --testMatch='**/*.integration.spec.ts' --runInBand",
    "test:integration:setup": "node scripts/create-test-databases.mjs && NODE_ENV=local TEST_DIRECT_USERS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/users_test npm run prisma:migrate:deploy",
    "docker:infra": "docker compose --env-file docker/.env.example -f docker/docker-compose.infra.yml up -d",
    "docker:infra:down": "docker compose --env-file docker/.env.example -f docker/docker-compose.infra.yml down",
    "docker:full": "docker compose --env-file docker/.env.example -f docker/docker-compose.full.yml up -d",
    "docker:full:down": "docker compose --env-file docker/.env.example -f docker/docker-compose.full.yml down"
  },
  "dependencies": {
    "@anatine/zod-nestjs": "2.0.12",
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.0.16",
    "@nestjs/config": "4.0.0",
    "@nestjs/core": "11.0.1",
    "@nestjs/cqrs": "11.0.1",
    "@nestjs/jwt": "11.0.1",
    "@nestjs/microservices": "11.0.1",
    "@nestjs/platform-express": "11.0.1",
    "@nestjs/platform-ws": "11.0.1",
    "@nestjs/schedule": "6.0.1",
    "@nestjs/swagger": "11.0.3",
    "@nestjs/terminus": "11.0.0",
    "@nestjs/websockets": "11.0.1",
    "@prisma/adapter-pg": "7.0.0",
    "@prisma/client": "7.0.0",
    "@willsoto/nestjs-prometheus": "6.0.2",
    "axios": "1.13.5",
    "bignumber.js": "9.3.0",
    "bullmq": "5.63.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "hbs": "4.2.0",
    "http-proxy-middleware": "3.0.5",
    "ioredis": "5.8.2",
    "marked": "17.0.1",
    "nats": "2.20.0",
    "pg": "8.16.3",
    "prom-client": "15.1.3",
    "puppeteer": "24.35.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "uuid": "9.0.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.18.0",
    "@nestjs/cli": "11.0.12",
    "@nestjs/schematics": "11.0.0",
    "@nestjs/testing": "11.0.1",
    "@types/express": "5.0.0",
    "@types/http-proxy-middleware": "1.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "22.10.7",
    "@types/pg": "^8.18.0",
    "@types/supertest": "6.0.2",
    "@types/uuid": "9.0.8",
    "concurrently": "^9.2.1",
    "cross-env": "10.1.0",
    "dotenv-cli": "11.0.0",
    "eslint": "9.26.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-prettier": "5.2.2",
    "globals": "16.0.0",
    "husky": "^9.1.7",
    "jest": "29.7.0",
    "pdf-parse": "^2.4.5",
    "prettier": "3.4.2",
    "prisma": "7.0.0",
    "rimraf": "6.0.1",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  }
}
